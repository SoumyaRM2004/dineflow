# ===== DineFlow Environment Variables =====
# Copy this file to .env and fill in your values

# Application
APP_NAME=DineFlow
APP_VERSION=0.1.0
DEBUG=true
ENVIRONMENT=development

# Server
HOST=0.0.0.0
PORT=8000

# Database (PostgreSQL)
DATABASE_URL=postgresql+asyncpg://dineflow:dineflow@localhost:5432/dineflow
DB_ECHO=false
DB_POOL_SIZE=20
DB_MAX_OVERFLOW=10

# JWT Authentication
JWT_SECRET_KEY=change-me-use-openssl-rand-hex-32-in-production
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Redis
REDIS_URL=redis://:dineflow_redis@localhost:6379/0

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=ap-south-1
S3_BUCKET_NAME=dineflow-assets

# CORS Origins (comma-separated)
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Password Reset
PASSWORD_RESET_TOKEN_EXPIRE_MINUTES=30

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=DineFlow
